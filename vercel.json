{
    "version": 2,
    "regions": [
        "bom1"
    ],
    "builds": [
        {
            "src": "backend/vercel/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "backend/vercel/index.py"
        }
    ]
}